# Copy this file to `.env` in the same directory as docker-compose.yml
# and fill in real values. `.env` is gitignored — never commit it.
#
# Every value below is optional EXCEPT the security-sensitive ones marked
# "CHANGE THIS". The system runs fully in safe simulated/heuristic mode
# without VIRUSTOTAL_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY /
# CROWDSTRIKE_* / DJANGO_* configured — same fallback pattern used
# throughout this codebase.

# ---------------------------------------------------------------------
# Threat intelligence (TIP Platform) — optional
# ---------------------------------------------------------------------
VIRUSTOTAL_API_KEY=

# ---------------------------------------------------------------------
# AI analysis (AI Orchestrator) — optional. Without either key, alerts
# are analyzed with the built-in heuristic scorer instead of a real LLM.
# ---------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------
# CrowdStrike Falcon (Response Engine) — optional. Without these,
# isolate_host/restore_host run in simulated mode.
# ---------------------------------------------------------------------
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Django Ticket Management System sync (AI Orchestrator) — optional.
# Without DJANGO_BASE_URL, incidents are never pushed to an external
# ticket system and the django_ticket_id/status fields just stay null.
# ---------------------------------------------------------------------
DJANGO_BASE_URL=
DJANGO_API_TOKEN=
DJANGO_TICKET_ENDPOINT=/api/tickets/
# Shared secret Django must send back in the X-Webhook-Secret header
# when calling POST /webhooks/django-ticket-update on the orchestrator.
DJANGO_WEBHOOK_SECRET=change-this-django-webhook-secret

# ---------------------------------------------------------------------
# Auth / RBAC — CHANGE THESE before exposing this past localhost.
# ---------------------------------------------------------------------
# Signs JWTs. Any long random string works, e.g. `openssl rand -hex 32`.
SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Shared secret services use to call each other (siem -> orchestrator ->
# tip/response). Must be the same value across all four services —
# docker-compose.yml already passes this one variable to all of them.
INTERNAL_SERVICE_TOKEN=change-this-internal-service-token

# First-run bootstrap admin account (created once, only if the `users`
# table is empty). Change the password via POST /auth/users or the
# dashboard immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ---------------------------------------------------------------------
# Database — defaults already match docker-compose.override.yml's
# postgres service. Only override if you change that service.
# ---------------------------------------------------------------------
POSTGRES_URL=postgresql+asyncpg://soc:soc@postgres:5432/soc_db
RUN_MIGRATIONS_ON_STARTUP=true
